<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:ShockUI.Views"
        xmlns:vm="using:ShockUI.ViewModels"
        x:Class="ShockUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1720"
        Height="980"
        MinWidth="1400"
        MinHeight="850"
        Title="ShockUI">

  <views:ShellView DataContext="{Binding Shell}" />
</Window>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ShockUI.ViewModels"
             xmlns:moduleVm="using:ShockUI.ViewModels.Modules"
             xmlns:models="using:ShockUI.Models.App"
             xmlns:moduleViews="using:ShockUI.Views.Modules"
             xmlns:shockui="using:ShockUI"
             x:Class="ShockUI.Views.ShellView"
             x:Name="Root"
             x:DataType="vm:ShellViewModel">

  <UserControl.Styles>

    <Style Selector="Border.sidebar-card">
      <Setter Property="Background" Value="#0D1B34"/>
      <Setter Property="BorderBrush" Value="#27476F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="Button.nav-button">
      <Setter Property="Background" Value="#182A49"/>
      <Setter Property="Foreground" Value="#F8FAFC"/>
      <Setter Property="BorderBrush" Value="#375A89"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style Selector="Button.nav-button-eng">
      <Setter Property="Background" Value="#0F1E38"/>
      <Setter Property="Foreground" Value="#CBD5E1"/>
      <Setter Property="BorderBrush" Value="#2D4A6A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Padding" Value="12,9"/>
      <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>
    <Style Selector="Button.nav-button-eng:disabled">
      <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <Style Selector="Button.sidebar-action">
      <Setter Property="Background" Value="#223250"/>
      <Setter Property="Foreground" Value="#F8FAFC"/>
      <Setter Property="BorderBrush" Value="#375A89"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="8,5"/>
    </Style>

    <!-- Slim chevron button for collapsing/expanding the sidebar.
         Sits in the sidebar header row; works in both states. -->
    <Style Selector="Button.sidebar-toggle">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#93C5FD"/>
      <Setter Property="BorderBrush" Value="#27476F"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Width"   Value="28"/>
      <Setter Property="Height"  Value="28"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment"   Value="Center"/>
    </Style>
    <Style Selector="Button.sidebar-toggle:pointerover">
      <Setter Property="Background" Value="#182A49"/>
    </Style>

  </UserControl.Styles>

  <UserControl.DataTemplates>
    <DataTemplate DataType="moduleVm:CameraControllerViewModel">
      <moduleViews:CameraControllerView />
    </DataTemplate>
    <DataTemplate DataType="moduleVm:VisNIRControllerViewModel">
      <moduleViews:VisNIRControllerView />
    </DataTemplate>
    <DataTemplate DataType="moduleVm:SwirControllerViewModel">
      <moduleViews:SwirControllerView />
    </DataTemplate>
    <DataTemplate DataType="moduleVm:PanTiltControllerViewModel">
      <moduleViews:PanTiltControllerView />
    </DataTemplate>
    <DataTemplate DataType="moduleVm:DeviceControllerViewModel">
      <moduleViews:DeviceControllerView />
    </DataTemplate>
  </UserControl.DataTemplates>

  <Grid ColumnDefinitions="Auto,*">

    <!-- Sidebar Border width is driven by the VM (250 expanded, 48 collapsed).
         The column is Auto so the main content area grows whenever the
         sidebar shrinks. -->
    <Border Grid.Column="0"
            Background="#08142A"
            BorderBrush="#27476F"
            BorderThickness="0,0,1,0"
            Width="{Binding SidebarWidth}">

      <!-- Two-row layout: header bar (always visible, holds the chevron)
                          + body (DockPanel — hidden when collapsed). -->
      <Grid RowDefinitions="Auto,*">

        <!-- Header bar: chevron at right when expanded, centred when collapsed. -->
        <Border Grid.Row="0" Padding="10,10,10,4">
          <Button Classes="sidebar-toggle"
                  Content="{Binding SidebarToggleGlyph}"
                  Command="{Binding ToggleSidebarCommand}"
                  ToolTip.Tip="{Binding SidebarToggleTooltip}"
                  HorizontalAlignment="Right"/>
        </Border>

        <!-- Sidebar body — hidden when collapsed so the chevron stays
             accessible on the slim rail. -->
        <DockPanel Grid.Row="1" Margin="14,4,14,14"
                   IsVisible="{Binding !IsSidebarCollapsed}">

        <Border DockPanel.Dock="Bottom"
                Classes="sidebar-card"
                Margin="0,12,0,0">
          <StackPanel Spacing="4">
            <TextBlock Text="Workspace" FontWeight="Bold" Foreground="#93C5FD"/>
            <TextBlock Text="Module host ready" Foreground="#E2E8F0"/>
            <!--
              Build version + timestamp. Bound to the static BuildInfo
              class so it's read once at startup. Updated automatically
              every build by MSBuild (see ShockUI.csproj).
            -->
            <TextBlock Text="{x:Static shockui:BuildInfo.DisplayString}"
                       Foreground="#64748B"
                       FontSize="10"
                       FontFamily="Consolas"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0"
                       ToolTip.Tip="Application version and build time"/>
          </StackPanel>
        </Border>

        <StackPanel Spacing="0">

          <!-- App title -->
          <StackPanel Spacing="2" Margin="0,0,0,16">
            <TextBlock Text="ShockUI" FontSize="20" FontWeight="Bold" Foreground="#F8FAFC"/>
            <TextBlock Text="Unified Engineering GUI" Foreground="#93C5FD"/>
          </StackPanel>

          <!-- Top-level modules (System Controller – always visible) -->
          <ItemsControl ItemsSource="{Binding TopLevelItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:NavigationItem">
                <Button Classes="nav-button"
                        Content="{Binding Label}"
                        Command="{Binding #Root.DataContext.NavigateCommand}"
                        CommandParameter="{Binding .}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Divider -->
          <Border BorderBrush="#27476F" BorderThickness="0,1,0,0" Margin="0,10,0,10"/>

          <!-- Engineering section header -->
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
              <TextBlock Text="Maintenance"
                         FontSize="11" FontWeight="Bold" Foreground="#93C5FD"/>
              <TextBlock Text="{Binding EngineeringStatusText}"
                         FontSize="10" Foreground="#64748B"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="sidebar-action"
                    Content="Lock"
                    Command="{Binding LockEngineeringCommand}"
                    IsVisible="{Binding IsEngineeringUnlocked}"
                    FontSize="11" Padding="8,4"/>
          </Grid>

          <!-- Password entry (locked state) -->
          <StackPanel Spacing="6"
                      IsVisible="{Binding !IsEngineeringUnlocked}"
                      Margin="0,0,0,10">
            <TextBox Text="{Binding PasswordEntry}"
                     PasswordChar="●"
                     Watermark="Enter password…"
                     Background="#0D1B34"
                     Foreground="#E2E8F0"
                     BorderBrush="#375A89"
                     FontSize="12">
              <!--
                Pressing Enter while focused on the password field fires
                the same command as the "Unlock Maintenance" button, so
                the operator doesn't need to reach for the mouse.
              -->
              <TextBox.KeyBindings>
                <KeyBinding Gesture="Enter"
                            Command="{Binding SubmitPasswordCommand}"/>
              </TextBox.KeyBindings>
            </TextBox>
            <TextBlock Text="Incorrect password"
                       Foreground="#EF4444"
                       FontSize="11"
                       IsVisible="{Binding PasswordError}"/>
            <Button Classes="sidebar-action"
                    Content="Unlock Maintenance"
                    Command="{Binding SubmitPasswordCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    FontSize="11"/>
          </StackPanel>

          <!-- Engineering modules (unlocked state) -->
          <ItemsControl ItemsSource="{Binding EngineeringItems}"
                        IsVisible="{Binding IsEngineeringUnlocked}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="models:NavigationItem">
                <Button Classes="nav-button-eng"
                        Content="{Binding Label}"
                        Command="{Binding #Root.DataContext.NavigateCommand}"
                        CommandParameter="{Binding .}"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>
      </DockPanel>
      </Grid>
    </Border>

    <Border Grid.Column="1" Background="#020B1D">
      <ContentControl Content="{Binding CurrentModule}"/>
    </Border>

  </Grid>
</UserControl>
